{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "paths": {
      "@paper-ui/tokens":       ["../../paper-ui/src/tokens"],
      "@paper-ui/utils":        ["../../paper-ui/src/utils"],
      "@paper-ui/core":         ["../../paper-ui/src/core"],
      "@paper-ui/components":   ["../../paper-ui/src/components"],
      "@paper-ui/components/*": ["../../paper-ui/src/components/*"]
    }
  },
  "include": ["stories", "src", "../../paper-ui/src"]
}
