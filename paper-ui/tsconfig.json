{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "paths": {
      "@paper-ui/tokens": ["./src/tokens"],
      "@paper-ui/utils": ["./src/utils"],
      "@paper-ui/core": ["./src/core"],
      "@paper-ui/components": ["./src/components"],
      "@paper-ui/components/*": ["./src/components/*"]
    }
  },
  "include": ["src"]
}
