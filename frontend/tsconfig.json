{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "paths": {
      "@/*": ["./src/*"],
      "@paper-ui/tokens": ["../paper-ui/src/tokens"],
      "@paper-ui/utils": ["../paper-ui/src/utils"],
      "@paper-ui/core": ["../paper-ui/src/core"],
      "@paper-ui/components": ["../paper-ui/src/components"],
      "@paper-ui/components/*": ["../paper-ui/src/components/*"]
    }
  },
  "include": ["src", "../paper-ui/src"],
  "exclude": ["src/stories"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
